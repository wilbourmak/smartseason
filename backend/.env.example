PORT=5000
JWT_SECRET=your_jwt_secret_key_here

# Firebase Configuration (using environment variables)
# Option 1: Use Firebase service account JSON file (recommended)
# Place serviceAccountKey.json in the backend folder
# Download from: Firebase Console > Project Settings > Service Accounts > Generate new private key

# Option 2: Use environment variables (for deployment)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBgkqhkiG9w0BAQE...\n-----END PRIVATE KEY-----\n"
